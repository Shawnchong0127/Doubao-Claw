{
  "name": "@doubao-claw/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Doubao AI API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "keywords": ["doubao", "ai", "bytedance", "sdk", "llm"],
  "license": "MIT",
  "dependencies": {
    "eventsource-parser": "^1.1.2"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "@types/node": "^20.0.0"
  },
  "engines": { "node": ">=18" }
}
